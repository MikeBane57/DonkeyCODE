{
  "manifest_version": 3,
  "name": "DonkeyCode",
  "version": "1.6.2",
  "description": "Lightweight user-script loader with session management for Chrome and Edge.",
  "permissions": ["scripting", "tabs", "storage", "alarms", "windows"],
  "host_permissions": ["https://api.github.com/*"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "DonkeyCode",
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
